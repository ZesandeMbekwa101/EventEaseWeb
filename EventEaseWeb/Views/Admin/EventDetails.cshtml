@model EventEaseWeb.Models.EventModel
@{
    ViewData["Title"] = "Event Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header">
    <h1>Event Details</h1>
</div>

<div class="content-card mb-4">
    <div class="content-card-header">
        <h2>@Model.EventName</h2>
    </div>
    <div style="padding:25px;">
        <p><strong>Date:</strong> @Model.EventDate.ToString("yyyy-MM-dd")</p>
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Venue:</strong> @Model.Venue?.VenueName</p>
    </div>
</div>

<a href="@Url.Action("EditEvent", "Admin", new { id = Model.EventID })"
   class="btn-action btn-complete ms-2">
    <i class="fas fa-edit me-2"></i> Update
</a>
<form asp-action="DeleteEvent" asp-controller="Admin" method="post" style="display:inline;">
    <input type="hidden" name="id" value="@Model.EventID" />
    <button type="submit" class="btn-action btn-danger ms-2"
            onclick="return confirm('Are you sure you want to delete this event?');">
        <i class="fas fa-trash me-2"></i> Delete
    </button>
</form>

<div class="mt-3">
    <a href="@Url.Action("Events", "Admin")" class="btn-action btn-view">
        <i class="fas fa-arrow-left me-2"></i> Back to Events
    </a>
</div>

<style>
    .btn-complete {
        background-color: #2E7D32;
        color: white;
        padding: 8px 16px;
        border-radius: 6px;
        border: none;
        font-size: 13px;
        font-weight: 600;
    }

    .btn-danger {
        background-color: #C62828;
        color: white;
        padding: 8px 16px;
        border-radius: 6px;
        border: none;
        font-size: 13px;
        font-weight: 600;
    }

    .ms-2 {
        margin-left: 8px;
    }
</style>