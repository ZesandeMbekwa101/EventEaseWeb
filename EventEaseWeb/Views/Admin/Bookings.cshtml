@{
    ViewData["Title"] = "Bookings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header">
    <h1>Bookings</h1>
</div>

<div class="content-card mb-3">
    <div style="padding:20px;">
        <input type="text" id="searchBooking" class="form-control"
               placeholder="🔍 Search by event or venue..."
               onkeyup="filterBookings()">
    </div>
</div>

<div class="content-card">
    <div class="content-card-header">
        <h2>All Bookings</h2>
    </div>

    <div class="table-responsive">
        <table class="admin-table" id="bookingTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Event ID</th>
                    <th>Venue ID</th>
                    <th>Booking Date</th>
                </tr>
            </thead>
            <tbody>
                <tr class="booking-row">
                    <td>1</td>
                    <td>1</td>
                    <td>1</td>
                    <td>2026-03-20</td>
                </tr>
                <tr class="booking-row">
                    <td>2</td>
                    <td>2</td>
                    <td>2</td>
                    <td>2026-04-05</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<script>
    function filterBookings() {
        var input = document.getElementById("searchBooking").value.toUpperCase();
        var rows = document.getElementById("bookingTable").getElementsByClassName("booking-row");
        for (var i = 0; i < rows.length; i++) {
            var eventId = rows[i].getElementsByTagName("td")[1].textContent.toUpperCase();
            var venueId = rows[i].getElementsByTagName("td")[2].textContent.toUpperCase();
            rows[i].style.display = (eventId.includes(input) || venueId.includes(input)) ? "" : "none";
        }
    }
</script>