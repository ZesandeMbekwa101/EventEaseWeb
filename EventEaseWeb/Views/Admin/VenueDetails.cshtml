@model EventEaseWeb.Models.VenueModel
@{
    ViewData["Title"] = "Venue Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header">
    <h1>Venue Details</h1>
</div>

<div class="content-card mb-4">
    <div class="content-card-header">
        <h2>@Model.VenueName</h2>
    </div>
    <div style="padding:25px;">
        <p><strong>Location:</strong> @Model.Location</p>
        <p><strong>Capacity:</strong> @Model.Capacity</p>
        @if (!string.IsNullOrEmpty(Model.Image))
        {
            <p><strong>Image:</strong></p>
            <img src="@Model.Image" alt="Venue Image" style="width:150px;height:150px;">
        }
    </div>
</div>

<!-- Edit & Delete Buttons -->
<a href="@Url.Action("EditVenue", "Admin", new { id = Model.VenueID })"
   class="btn-action btn-complete ms-2">
    <i class="fas fa-edit me-2"></i> Update
</a>
<form asp-action="DeleteVenue" asp-controller="Admin" method="post" style="display:inline;">
    <input type="hidden" name="id" value="@Model.VenueID" />
    <button type="submit" class="btn-action btn-danger ms-2"
            onclick="return confirm('Are you sure you want to delete this venue?');">
        <i class="fas fa-trash me-2"></i> Delete
    </button>
</form>

<div class="mt-3">
    <a href="@Url.Action("Venues", "Admin")" class="btn-action btn-view">
        <i class="fas fa-arrow-left me-2"></i> Back to Venues
    </a>
</div>

<style>
    .btn-complete {
        background-color: #2E7D32;
        color: white;
        padding: 8px 16px;
        border-radius: 6px;
        border: none;
        font-size: 13px;
        font-weight: 600;
    }

    .btn-danger {
        background-color: #C62828;
        color: white;
        padding: 8px 16px;
        border-radius: 6px;
        border: none;
        font-size: 13px;
        font-weight: 600;
    }

    .ms-2 {
        margin-left: 8px;
    }
</style>