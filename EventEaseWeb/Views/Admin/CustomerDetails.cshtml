@*@model List<DerekAutoCare.Models.Booking>*@

@{
    ViewData["Title"] = "Customer Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
   @* var customer = ViewBag.Customer as DerekAutoCare.Models.Customer;*@
}

<div class="admin-header">
    <h1>Customer Details</h1>
</div>

<div class="content-card mb-4">
    <div class="content-card-header">
       @* <h2>@customer.FullName</h2>*@
    </div>
    <div style="padding: 25px;">
        <div class="row">
            <div class="col-md-6">
               @* <p><strong>Email:</strong> @customer.Email</p>*@
              @*  <p><strong>Phone:</strong> @customer.Phone</p>*@
            </div>
            <div class="col-md-6">
               @* <p><strong>Member Since:</strong> @customer.CreatedAt.ToString("MMMM dd, yyyy")</p>*@
                <p><strong>Total Bookings:</strong> @Model.Count</p>
            </div>
        </div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header">
        <h2>Booking History</h2>
    </div>
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Service</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Payment</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var booking in Model)
                    {
                        <tr>
                            <td>#@booking.Id</td>
                            <td>@booking.Service.Name</td>
                            <td>@booking.BookingDate.ToString("MMM dd, yyyy")</td>
                            <td>R@(booking.TotalAmount.ToString("N2"))</td>
                            <td>
                                <span class="status-badge status-@booking.Status.ToLower()">
                                    @booking.Status
                                </span>
                            </td>
                            <td>
                                <span class="status-badge status-@booking.PaymentStatus.ToLower()">
                                    @booking.PaymentStatus
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align: center; color: #999; padding: 40px;">
                            No bookings found
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a href="@Url.Action("Customers", "Admin")" class="btn-action btn-view">
        <i class="fas fa-arrow-left me-2"></i> Back to Customers
    </a>
</div>
