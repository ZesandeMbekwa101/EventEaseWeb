@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header d-flex justify-content-between align-items-center">

    <div>
        <h1>Dashboard</h1>
        <p>Overview of EventEase</p>
    </div>

    <!-- Search + Login -->
    <div class="d-flex justify-content-center mt-4">

        <div class="input-group" style="max-width:500px;">

            <span class="input-group-text">
                <i class="fa fa-search"></i>
            </span>

            <input type="text" class="form-control" placeholder="Search bookings...">
        </div>
       
        <a href="/Account/Login" class="btn btn-primary">
            Login
        </a>

    </div>
    </div>

<div class="stats-grid">
    <div class="stat-card stat-primary">
        <div class="stat-icon">
            <i class="fas fa-calendar-check"></i>
        </div>
        <div class="stat-content">
            <h3>@ViewBag.TotalBookings</h3>
            <p>Total Bookings</p>
        </div>
    </div>

    <div class="stat-card stat-warning">
        <div class="stat-icon">
            <i class="fas fa-clock"></i>
        </div>
        <div class="stat-content">
            <h3>@ViewBag.PendingBookings</h3>
            <p>Pending Appointments</p>
        </div>
    </div>

    <div class="stat-card stat-success">
        <div class="stat-icon">
            <i class="fas fa-check-circle"></i>
        </div>
        <div class="stat-content">
            <h3>@ViewBag.CompletedBookings</h3>
            <p>Completed Services</p>
        </div>
    </div>

    <div class="stat-card stat-info">
        <div class="stat-icon">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-content">
            <h3>@ViewBag.TotalCustomers</h3>
            <p>Total Customers</p>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-lg-12">
        <div class="content-card">
            <div class="content-card-header">
                <h3>Recent Bookings</h3>
            </div>
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                     
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>