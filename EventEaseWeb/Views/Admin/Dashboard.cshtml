@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Safely get session values
    var username = HttpContextAccessor.HttpContext.Session.GetString("UserName");
    var isLoggedIn = !string.IsNullOrEmpty(username);
}

<!-- Display welcome message once -->
@if (!string.IsNullOrEmpty(ViewBag.LoginMessage) && isLoggedIn)
{
    <div class="alert alert-success">
        @ViewBag.LoginMessage
    </div>

    <script>
        setTimeout(() => {
            const alert = document.querySelector('.alert-success');
            if (alert) {
                alert.style.transition = 'opacity 0.5s, max-height 0.5s';
                alert.style.opacity = '0';
                alert.style.maxHeight = '0';
                setTimeout(() => alert.remove(), 500);
            }
        }, 4000); // disappears after 4 seconds
    </script>
}
@if (TempData["LogoutMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["LogoutMessage"]
    </div>

    <script>
        setTimeout(() => {
            const alert = document.querySelector('.alert-danger');
            if (alert) {
                alert.style.transition = 'opacity 0.5s, max-height 0.5s';
                alert.style.opacity = '0';
                alert.style.maxHeight = '0';
                setTimeout(() => alert.remove(), 500);
            }
        }, 4000);
    </script>
}

<div class="admin-header d-flex justify-content-between align-items-center">
    <div>
        <h1>Dashboard</h1>
        <p>Overview of EventEase</p>
    </div>

    <div class="d-flex justify-content-center mt-4">
        <div class="input-group" style="max-width:500px;">
            <span class="input-group-text">
                <i class="fa fa-search"></i>
            </span>
            <input type="text" class="form-control" placeholder="Search bookings...">
        </div>

        @* Show login button only if NOT logged in *@
        @if (!isLoggedIn)
        {
            <a href="/Account/Login" class="btn btn-primary ms-2">
                Login
            </a>
        }

    </div>
</div>

<div class="stats-grid">
    <div class="stat-card stat-primary">
        <div class="stat-icon"><i class="fas fa-book-open"></i></div>
        <div class="stat-content">
            <h3>@(isLoggedIn ? ViewBag.TotalBookings : "-")</h3>
            <p>Total Bookings</p>
        </div>
    </div>

    <div class="stat-card stat-warning">
        <div class="stat-icon"><i class="fas fa-building"></i></div>
        <div class="stat-content">
            <h3>@(isLoggedIn ? ViewBag.TotalVenues : "-")</h3>
            <p>Total Venues</p>
        </div>
    </div>

    <div class="stat-card stat-success">
        <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
        <div class="stat-content">
            <h3>@(isLoggedIn ? ViewBag.TotalEvents : "-")</h3>
            <p>Total Events</p>
        </div>
    </div>

    <div class="stat-card stat-info">
        <div class="stat-icon"><i class="fas fa-users"></i></div>
        <div class="stat-content">
            <h3>@(isLoggedIn ? ViewBag.TotalCustomers : "-")</h3>
            <p>Total Customers</p>
        </div>
    </div>
</div>