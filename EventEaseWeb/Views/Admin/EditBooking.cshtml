@model EventEaseWeb.Models.BookingModel
@{
    ViewData["Title"] = "Edit Booking";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header">
    <h1>Edit Booking</h1>
</div>

<div class="content-card mb-4">
    <div class="content-card-header">
        <h2>Booking Information</h2>
    </div>

    <form asp-action="EditBooking" method="post">
        <input type="hidden" asp-for="BookingID" />

        <!-- Event -->
        <div class="mb-3">
            <label>Event</label>
            <select asp-for="EventID" asp-items="ViewBag.Events" class="form-control">
                <option value="0">-- Select Event --</option>
            </select>
            <span asp-validation-for="EventID" class="text-danger"></span>
        </div>


        <!-- Venue -->
        <div class="mb-3">
            <label>Venue</label>
            <select asp-for="VenueID" asp-items="ViewBag.Venues" class="form-control">
                <option value="0">-- Select Venue --</option>
            </select>
            <span asp-validation-for="VenueID" class="text-danger"></span>
        </div>

        <!-- Client -->
        <div class="mb-3">
            <label>Client</label>
            <select asp-for="BookedBy" asp-items="ViewBag.Clients" class="form-control">
                <option value="0">-- Select Client --</option>
            </select>
            <span asp-validation-for="BookedBy" class="text-danger"></span>
        </div>

        <!-- Date -->
        <div class="mb-3">
            <label>Booking Date</label>
            <input asp-for="BookingDate" type="date" class="form-control"
                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
            <span asp-validation-for="BookingDate" class="text-danger"></span>
        </div>

        <button type="submit" class="btn-action btn-complete">
            <i class="fas fa-save me-2"></i> Save Changes
        </button>

        <a href="@Url.Action("BookingDetails", "Admin", new { id = Model.BookingID })"
           class="btn-action btn-view ms-2">
            Cancel
        </a>
    </form>
</div>
<style>
    .btn-complete {
        background-color: #2E7D32;
        color: white;
        padding: 8px 16px;
        border-radius: 6px;
        border: none;
        font-size: 13px;
        font-weight: 600;
    }

    .btn-view {
        background-color: #1976D2;
        color: white;
        padding: 8px 16px;
        border-radius: 6px;
        border: none;
        font-size: 13px;
        font-weight: 600;
        margin-left: 8px;
    }

    .ms-2 {
        margin-left: 8px;
    }
</style>